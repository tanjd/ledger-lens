# =============================================================================
# Backend Configuration
# =============================================================================

# Environment: "dev" or "prd"
ENV=dev

# Directory where IBKR CSV files are watched and SQLite DB is stored
# Default: ./data (relative to backend working directory)
DATA_DIR=./data

# CORS origins allowed to call the API (comma-separated)
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# Frontend Configuration
# =============================================================================

# Backend API URL (used by Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000
